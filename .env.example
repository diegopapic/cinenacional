# =============================================================================
# CineNacional - Variables de entorno
# =============================================================================
# Copiar este archivo a .env.local y completar con valores reales.
# NUNCA commitear archivos .env con credenciales reales.
#
# Para generar NEXTAUTH_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Para generar IP_HASH_SALT:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# =============================================================================

# --- Base de datos PostgreSQL ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cinenacional?schema=public&connection_limit=5&pool_timeout=10&connect_timeout=10&statement_timeout=30000"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/cinenacional?schema=public"

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=   # Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# --- Admin inicial (cambiar después del primer login) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=admin

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- TMDB ---
TMDB_ACCESS_TOKEN=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Analytics ---
ANALYTICS_EXCLUDED_IPS=
IP_HASH_SALT=   # Generar con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

# --- Redis (rate limiting persistente) ---
# En desarrollo es opcional (fallback a in-memory). En producción se recomienda.
# REDIS_URL=redis://localhost:6379

# --- Node ---
NODE_ENV=development
